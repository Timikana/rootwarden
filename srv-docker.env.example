# ================================================================
# RootWarden - Fichier de configuration
# ================================================================
# Copiez ce fichier : cp srv-docker.env.example srv-docker.env
# Puis remplissez chaque valeur avant de lancer docker-compose.
#
# Générer des clés aléatoires sécurisées :
#   openssl rand -hex 32   → pour SECRET_KEY, ENCRYPTION_KEY, API_KEY
#   openssl rand -hex 16   → pour une clé 128 bits
#
# ⚠️  SECURITE - A lire avant le deploiement en production :
#
#   1. Changez TOUTES les valeurs par defaut (SECRET_KEY, API_KEY, DB_PASSWORD, etc.)
#   2. Protegez ce fichier : chmod 600 srv-docker.env
#   3. Ne commitez JAMAIS ce fichier avec des secrets reels (il est dans .gitignore)
#   4. Apres le premier demarrage, supprimez INIT_SUPERADMIN_PASSWORD de ce fichier
#   5. Le mot de passe superadmin est auto-genere si INIT_SUPERADMIN_PASSWORD est vide
#   6. Le changement de mot de passe est force a la premiere connexion
# ================================================================


# ----------------------------------------------------------------
# Chiffrement des mots de passe en base (AES-256)
# OBLIGATOIRE - ne jamais laisser vide
# ----------------------------------------------------------------
SECRET_KEY=CHANGEZ_MOI_openssl_rand_hex_32

# Ancienne clé (uniquement si vous migrez depuis une version précédente)
# Laissez vide si vous installez pour la première fois
OLD_SECRET_KEY=

# Clé de protection supplémentaire (optionnel - non utilisée par le backend Python actuellement)
# ENCRYPTION_KEY=CHANGEZ_MOI_openssl_rand_hex_32


# ----------------------------------------------------------------
# Clé d'API - authentifie les requêtes du frontend vers le backend
# OBLIGATOIRE - ne jamais laisser vide
# ----------------------------------------------------------------
API_KEY=CHANGEZ_MOI_openssl_rand_hex_32


# ----------------------------------------------------------------
# Installation - mot de passe initial du superadmin
#
# Utilise UNIQUEMENT au premier demarrage (install.sh).
# Si vide, un mot de passe aleatoire est genere et
# affiche dans les logs Docker (docker logs <conteneur_php>).
# Ignore apres le premier demarrage.
# Les autres utilisateurs sont crees depuis l'interface Admin.
# ----------------------------------------------------------------
# INIT_SUPERADMIN_PASSWORD=


# ----------------------------------------------------------------
# Branding - personnalisation de l'interface (white-label)
#
# APP_NAME    : nom affiché dans le menu, le titre des pages et la page de login
# APP_TAGLINE : sous-titre affiché sur la page de login
# APP_COMPANY : nom de votre entreprise/client (ex: Piscines MAGILINE)
#               Affiché dans le menu et sur la page de login
#               Laissez vide pour ne rien afficher
# ----------------------------------------------------------------
APP_NAME=RootWarden
APP_TAGLINE=Gestion SSH centralisée
APP_COMPANY=


# ----------------------------------------------------------------
# Serveur
# ----------------------------------------------------------------
SERVER_NAME=localhost
SERVER_ADMIN=admin@example.com


# ----------------------------------------------------------------
# Base de données MySQL
# ----------------------------------------------------------------
DB_HOST=db
DB_NAME=rootwarden
DB_USER=rootwarden_user
DB_PASSWORD=CHANGEZ_MOI_mot_de_passe_bdd
# DB_PORT=3306  # Port MySQL (défaut : 3306) - décommenter uniquement si non-standard

# MySQL Docker - doit correspondre aux valeurs DB_* ci-dessus
MYSQL_ROOT_PASSWORD=CHANGEZ_MOI_mot_de_passe_root_mysql
MYSQL_DATABASE=${DB_NAME}
MYSQL_USER=${DB_USER}
MYSQL_PASSWORD=${DB_PASSWORD}


# ----------------------------------------------------------------
# Ports exposés
# ----------------------------------------------------------------
HTTP_PORT=8080
HTTPS_PORT=8443
PYTHON_PORT=5000
MYSQL_PORT=3306


# ----------------------------------------------------------------
# URLs de l'application (utilisées par le frontend JS)
# ----------------------------------------------------------------
URL_HTTP=http://${SERVER_NAME}:${HTTP_PORT}
URL_HTTPS=https://${SERVER_NAME}:${HTTPS_PORT}
API_URL=https://${SERVER_NAME}:${PYTHON_PORT}


# ----------------------------------------------------------------
# SSL - mode de gestion du certificat
#
#   auto     (défaut) : certificat auto-signé généré au premier démarrage.
#                        Idéal pour les tests ou les LAN internes.
#
#   custom            : vous fournissez vos propres certificats (Let's Encrypt,
#                        certificat d'entreprise…).
#                        Montez vos fichiers dans ./certs/ et renseignez les
#                        chemins ci-dessous. Le conteneur refusera de démarrer
#                        si les fichiers sont absents.
#
#   disabled          : TLS entièrement désactivé côté Apache.
#                        Utilisez ce mode si un reverse proxy (Nginx, Traefik,
#                        Caddy, HAProxy…) gère le TLS en amont.
#                        Le port 443 n'est alors plus nécessaire.
# ----------------------------------------------------------------
SSL_MODE=auto

# Chemin des certificats (utilisé seulement si SSL_MODE=custom)
SSL_CERT_PATH=/var/www/certs/custom.crt
SSL_KEY_PATH=/var/www/certs/custom.pem

# Sujet du certificat auto-signé (utilisé seulement si SSL_MODE=auto)
CERT_INFO=/C=FR/ST=IDF/L=Paris/O=MonOrganisation/OU=IT/CN=${SERVER_NAME}


# ----------------------------------------------------------------
# CORS - domaine autorisé à appeler le backend Python
# ----------------------------------------------------------------
CORS_ORIGINS=${SERVER_NAME}


# ----------------------------------------------------------------
# SSH
# ----------------------------------------------------------------
SSH_TIMEOUT=360


# ----------------------------------------------------------------
# OpenCVE - scan de vulnérabilités (CVE) sur les serveurs gérés
#
# Supporte :
#   - opencve.io (cloud)       → OPENCVE_URL=https://app.opencve.io
#                                 Utilisez OPENCVE_USERNAME + OPENCVE_PASSWORD (Basic Auth)
#   - instance on-prem v2      → OPENCVE_URL=https://opencve.mondomaine.com
#                                 Utilisez OPENCVE_TOKEN (Bearer token, prioritaire)
#
# Authentification (priorité) :
#   1. OPENCVE_TOKEN (Bearer) - recommandé pour on-prem v2
#   2. OPENCVE_USERNAME + OPENCVE_PASSWORD (Basic Auth) - cloud opencve.io
#   Laissez tout vide pour désactiver le module CVE.
# ----------------------------------------------------------------
OPENCVE_URL=https://app.opencve.io

# Bearer token pour OpenCVE v2 on-prem (prioritaire si défini)
# Généré dans : OpenCVE → Settings → API Keys
# OPENCVE_TOKEN=opc_org.xxxxx.yyyyyyyyyyyyyyyyyyy

# Basic Auth pour opencve.io cloud (fallback si pas de token)
OPENCVE_USERNAME=
OPENCVE_PASSWORD=

# Durée du cache des réponses OpenCVE (secondes). 3600 = 1 heure.
CVE_CACHE_TTL=3600

# Seuil CVSS par défaut (utilisé si l'utilisateur ne choisit pas de seuil).
# 0.0 = tout afficher | 4.0 = MEDIUM+ | 7.0 = HIGH+ | 9.0 = CRITICAL seulement
CVE_MIN_CVSS=7.0


# ----------------------------------------------------------------
# Notifications email (rapports CVE, reset mdp, bienvenue)
#
# MAIL_ENABLED=true pour activer l'envoi.
# MAIL_TO accepte plusieurs adresses séparées par des virgules.
#
# Exemples de configuration :
#
#   SMTP classique (OVH, Gmail, etc.) :
#     MAIL_SMTP_HOST=ssl0.ovh.net
#     MAIL_SMTP_PORT=465    MAIL_SMTP_TLS=false  (SMTPS)
#     - ou -
#     MAIL_SMTP_PORT=587    MAIL_SMTP_TLS=true   (STARTTLS)
#     MAIL_SMTP_USER=xxx    MAIL_SMTP_PASSWORD=xxx
#
#   Exchange Online Protection (relay Microsoft 365) :
#     MAIL_SMTP_HOST=mondomaine-fr.mail.protection.outlook.com
#     MAIL_SMTP_PORT=25     MAIL_SMTP_TLS=false
#     MAIL_SMTP_USER=       MAIL_SMTP_PASSWORD=
#     (pas d'auth, IP du serveur Docker whitelistée dans Exchange)
#
# MAIL_DEBUG=true → logs SMTP détaillés dans docker logs php
# ----------------------------------------------------------------
MAIL_ENABLED=false
MAIL_FROM=noreply@mondomaine.com
MAIL_TO=securite@mondomaine.com
MAIL_SMTP_HOST=smtp.mondomaine.com
MAIL_SMTP_PORT=587
MAIL_SMTP_USER=
MAIL_SMTP_PASSWORD=
MAIL_SMTP_TLS=true
MAIL_DEBUG=false


# ----------------------------------------------------------------
# Webhooks - notifications Slack / Teams / Discord
#
# Envoie des alertes automatiques sur les événements importants :
#   cve_critical    - CVE critique détectée lors d'un scan
#   cve_high        - CVE haute détectée lors d'un scan
#   deploy_complete - Déploiement SSH terminé
#   server_offline  - Serveur détecté hors ligne
#   update_complete - Mise à jour APT terminée
#
# Types supportés : slack, teams, discord, generic
# ----------------------------------------------------------------
# WEBHOOK_ENABLED=true
# WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ
# WEBHOOK_TYPE=slack
# WEBHOOK_EVENTS=cve_critical,cve_high,deploy_complete,server_offline


# ----------------------------------------------------------------
# Session - durée d'inactivité avant déconnexion automatique
# ----------------------------------------------------------------
# SESSION_TIMEOUT=30  # En minutes (défaut : 30)

# ----------------------------------------------------------------
# Politique de mot de passe - expiration automatique
# ----------------------------------------------------------------
# PASSWORD_EXPIRY_DAYS=90  # Jours avant expiration (défaut : 0 = désactivé)
# PASSWORD_WARN_DAYS=14    # Jours avant expiration pour afficher un avertissement


# ----------------------------------------------------------------
# Rétention des logs - purge automatique des anciens enregistrements
# ----------------------------------------------------------------
# LOG_RETENTION_DAYS=90       # Jours de conservation (défaut : 0 = désactivé, jamais purgé)
# CVE_SCAN_RETENTION=10       # Nombre de scans CVE conservés par serveur (défaut : 10)


# ----------------------------------------------------------------
# Backup automatique de la base de données
# ----------------------------------------------------------------
# BACKUP_ENABLED=true             # Active le backup quotidien (défaut : false)
# BACKUP_RETENTION_DAYS=30        # Jours de conservation des dumps (défaut : 30)


# ----------------------------------------------------------------
# Mode Debug - UNIQUEMENT pour le développement local
#
# DEBUG_MODE=true active :
#   • Logging Python niveau DEBUG (requêtes SSH, déchiffrement, stack traces)
#   • Flask en mode debug (rechargement automatique, erreurs détaillées)
#   • PHP : error_reporting(E_ALL) + display_errors=On
#   • Réponses d'erreur détaillées dans l'API REST
#
# LOG_LEVEL : niveau de log Python indépendant du mode debug.
#   Valeurs : DEBUG | INFO | WARNING | ERROR | CRITICAL
#   Par défaut : DEBUG si DEBUG_MODE=true, sinon INFO
#
# ⚠️  NE JAMAIS activer DEBUG_MODE=true en production :
#     expose des informations sensibles (clés, mots de passe, traces).
# ----------------------------------------------------------------
DEBUG_MODE=false
# LOG_LEVEL=INFO

# ----------------------------------------------------------------
# test-server (profile preprod uniquement)
#
# Le container test-server refuse de demarrer si ces deux variables
# ne sont pas definies. Les fallbacks par defaut ont ete supprimes
# en v1.17.0 (audit securite). Genere des mots de passe forts :
#   openssl rand -base64 24
# ----------------------------------------------------------------
# TEST_SERVER_ROOT_PASSWORD=CHANGEZ_MOI_root_preprod
# TEST_SERVER_USER_PASSWORD=CHANGEZ_MOI_testuser_preprod

# ----------------------------------------------------------------
# Feature flags - toggles ON/OFF de modules entiers.
#
# Default : true (les modules sont actifs si la variable est absente).
# Quand un flag est sur "false" :
#   - Backend Python : le blueprint correspondant n'est pas enregistre,
#     toutes les routes /<module>/* retournent 404
#   - PHP : feature_enabled('xxx') retourne false, le menu cache l'entree,
#     /<module>/index.php abort en 404
#
# Apres modification, redemarrer les conteneurs :
#   docker compose up -d
# ----------------------------------------------------------------
WAZUH_ENABLED=true
